monitor=,1920x1080@240,auto,1

# Переменные
$mainMod = SUPER
$terminal = kitty
$terminal1 = alacritty
$fileManager = thunar
$ipc = noctalia msg

# 1. Базовые программы
bind = $mainMod, RETURN, exec, $terminal #"Kitty"
bind = $mainMod SHIFT, RETURN, exec, $fileManager #"Thunar"
bind = $mainMod, W, exec, firefox #"Firefox"
bind = $mainMod, P, exec, $terminal1 -e btop #"btop"

# 2. Хоткеи оболочки
bind = $mainMod, D, exec, $ipc panel-toggle launcher #"Лаунчер"
bind = , Print, exec, $ipc screenshot-region #"Скриншот"
bind = $mainMod, V, exec, $ipc panel-toggle clipboard #"Буфер обмена"
bind = $mainMod, L, exec, $ipc screen-lock #"Заблокировать"
bind = $mainMod SHIFT, W, exec, $ipc panel-toggle wallpaper #"Обои"
bindr = $mainMod SHIFT, Shift_L, exec, $ipc panel-toggle control-center #"Панель управления"
bindr = $mainMod CONTROL, Control_L, exec, $ipc settings-toggle #"Настройки"
bindr = $mainMod ALT, Alt_L, exec, $ipc panel-toggle session #"Меню сеанса"

# 3. Скрипты
bind = $mainMod SHIFT, U, exec, $terminal --hold zsh $XDG_CONFIG_HOME/hypr/scripts/update.sh #"Обновление пакетов"
bind = $mainMod SHIFT, H, exec, $terminal --hold zsh -c "vim $XDG_CONFIG_HOME/hypr/hyprland.conf" #"Конфиг hyprland"
bind = $mainMod, Print, exec, grim -g "$(slurp)" - | satty --filename - --fullscreen --output-filename ~/Изображения/Screenshots/satty-$(date '+%Y%m%d-%H%M%S').png #"Скриншот satty"
#bind = $mainMod, V, exec, cliphist list | rofi -dmenu -p "Буфер обмена" | cliphist decode | wl-copy #"Буфер обмена"
#bind = $mainMod SHIFT, V, exec, cliphist wipe #"Очистить буфер обмена"

# 4. Приложения
bind = $mainMod, T, exec, flatpak run org.telegram.desktop #"Telegram"
bind = $mainMod, G, exec, steam #"Steam"
bind = $mainMod, N, exec, throne #"Throne"
bind = $mainMod SHIFT, G, exec, flatpak run org.prismlauncher.PrismLauncher #"Prism"

# 5. Управление окнами
bind = $mainMod SHIFT, Q, killactive #"Закрыть"
bind = $mainMod, F, fullscreen, 1 #"Развернуть"
bind = $mainMod SHIFT, F, fullscreen, 0 #"Полноэкранный режим"
bind = $mainMod CONTROL, F, togglefloating, #"Плавающий режим"
bindm = $mainMod, mouse:272, movewindow #"Передвинуть"
bindm = $mainMod, mouse:273, resizewindow #"Масштабировать"

# 6. Управление Hyprland
bind = $mainMod SHIFT, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit #"Выйти из WM"

# 7. Перемещение фокуса
bind = $mainMod, left, movefocus, l #"Влево"
bind = $mainMod, right, movefocus, r #"Вправо"
bind = $mainMod, up, movefocus, u #"Вверх"
bind = $mainMod, down, movefocus, d #"Вниз"
bind = $mainMod, TAB, cyclenext #"Следующее"

# 8. Перемещение по столам
bind = $mainMod, 1, workspace, 1 #"1"
bind = $mainMod, 2, workspace, 2 #"2"
bind = $mainMod, 3, workspace, 3 #"3"
bind = $mainMod, 4, workspace, 4 #"4"
bind = $mainMod, 5, workspace, 5 #"5"
bind = $mainMod, 6, workspace, 6 #"6"
bind = $mainMod, 7, workspace, 7 #"7"
bind = $mainMod, 8, workspace, 8 #"8"
bind = $mainMod, 9, workspace, 9 #"9"
bind = $mainMod, 0, workspace, 10 #"10"
bind = $mainMod, S, togglespecialworkspace #"Скрытый"
bind = $mainMod SHIFT, 1, movetoworkspace, 1 #"Окно на 1"
bind = $mainMod SHIFT, 2, movetoworkspace, 2 #"Окно на 2"
bind = $mainMod SHIFT, 3, movetoworkspace, 3 #"Окно на 3"
bind = $mainMod SHIFT, 4, movetoworkspace, 4 #"Окно на 4"
bind = $mainMod SHIFT, 5, movetoworkspace, 5 #"Окно на 5"
bind = $mainMod SHIFT, 6, movetoworkspace, 6 #"Окно на 6"
bind = $mainMod SHIFT, 7, movetoworkspace, 7 #"Окно на 7"
bind = $mainMod SHIFT, 8, movetoworkspace, 8 #"Окно на 8"
bind = $mainMod SHIFT, 9, movetoworkspace, 9 #"Окно на 9"
bind = $mainMod SHIFT, 0, movetoworkspace, 10 #"Окно на 10"
bind = $mainMod SHIFT, S, movetoworkspace, special #"Окно на скрытый"

exec-once = noctalia

general {
  gaps_in = 3
  gaps_out = 5
  border_size = 1
}

decoration {
  rounding = 14
  rounding_power = 2

  active_opacity = 1.0
  inactive_opacity = 0.9

  shadow {
    enabled = false
  }

  blur {
    enabled = true
    size = 3
    passes = 4
    vibrancy = 0.15
    vibrancy_darkness = 2.5
    #noise = 0.008
    #contrast = 0.9
    brightness = 0.9
    popups = true
    popups_ignorealpha = 0.3
  }

}

animations {
    enabled = yes

    bezier = wind,   0.05, 0.9,  0.1, 1.05
    bezier = winIn,  0.1,  0.9,  0.1, 1.1
    bezier = winOut, 0.3, -0.3,  0,   1.2
    bezier = liner,  1,    1,    1,   1

    animation = windows,     1, 6, wind, slide
    animation = windowsIn,   1, 6, winIn, slide
    animation = windowsOut,  1, 5, winOut, slide
    animation = windowsMove, 1, 5, wind, slide
    animation = border,      1, 1, liner
#    animation = borderangle, 1, 30, liner, loop
    animation = fade,        1, 10, default
    animation = workspaces,  1, 5, wind, slidefade 100%
}

layerrule {
    name = noctalia
    match:namespace = ^noctalia-(bar-.+|notification|dock|panel)$
    ignore_alpha = 0.5
    blur = true
    blur_popups = true
}

input {
  kb_layout = us,ru
  kb_options = grp:win_space_toggle

  sensitivity = -0.2
  accel_profile = flat
}

# For Noctalia Color templates
source = /home/indar4ik/.config/hypr/noctalia.conf
